<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <label>Contact_After_Update_Created</label>

    <!-- Record-triggered autolaunched flow on Contact (before save) -->
    <processType>AutoLaunchedFlow</processType>

    <!-- Start element: runs on Contact create or update -->
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <object>Contact</object>
        <recordTriggerType>CreateOrUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
        <connector>
            <targetReference>Assign_LeadSource_Web</targetReference>
        </connector>
    </start>

    <!-- Set LeadSource on the triggering Contact record -->
    <assignments>
        <name>Assign_LeadSource_Web</name>
        <label>Set Lead Source to Web</label>
        <locationX>176</locationX>
        <locationY>80</locationY>
        <assignmentItems>
            <assignToReference>$Record.LeadSource</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Web</stringValue>
            </value>
        </assignmentItems>
    </assignments>

    <status>Active</status>
</Flow>

